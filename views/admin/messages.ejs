<%- include('../partials/admin-header') %>
<div class="admin-content">
  <div class="admin-header">
    <h1>Mensagens</h1>
  </div>
  <div class="card">
    <div class="card-body">
      <% if (messages && messages.length > 0) { %>
        <table class="table">
          <thead>
            <tr>
              <th>Nome</th>
              <th>Email</th>
              <th>Assunto</th>
              <th>Mensagem</th>
              <th>Data</th>
              <th>Status</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% messages.forEach(function(m) { %>
              <tr class="<%= !m.read ? 'unread' : '' %>">
                <td><%= m.name %></td>
                <td><a href="mailto:<%= m.email %>"><%= m.email %></a></td>
                <td><%= m.subject || '—' %></td>
                <td class="msg-preview"><a href="/admin/messages/<%= m.id %>" class="msg-preview-link"><%= m.message.substring(0, 100) %><%= m.message.length > 100 ? '...' : '' %></a></td>
                <td><%= new Date(m.created_at).toLocaleString('pt-BR') %></td>
                <td><span class="badge <%= m.read ? 'badge-read' : 'badge-unread' %>"><%= m.read ? 'Lida' : 'Não lida' %></span></td>
                <td class="actions">
                  <a href="/admin/messages/<%= m.id %>" class="btn btn-sm btn-view" title="Ler mensagem">
                    <i class="fas fa-eye"></i>
                  </a>
                  <% if (!m.read) { %>
                    <form action="/admin/messages/read/<%= m.id %>" method="POST" class="inline-form">
                      <button type="submit" class="btn btn-sm btn-edit" title="Marcar como lida">
                        <i class="fas fa-check"></i>
                      </button>
                    </form>
                  <% } %>
                  <form action="/admin/messages/delete/<%= m.id %>" method="POST" class="inline-form" onsubmit="return confirm('Tem certeza?')">
                    <button type="submit" class="btn btn-sm btn-delete" title="Excluir">
                      <i class="fas fa-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <p class="empty-state">Nenhuma mensagem recebida.</p>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/admin-footer') %>
