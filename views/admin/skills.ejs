<%- include('../partials/admin-header') %>
<div class="admin-content">
  <div class="admin-header">
    <h1>Habilidades</h1>
  </div>
  <div class="card">
    <div class="card-header">
      <h2>Nova Habilidade</h2>
    </div>
    <div class="card-body">
      <form action="/admin/skills" method="POST" class="admin-form form-inline">
        <div class="form-row">
          <div class="form-group">
            <input type="text" name="name" placeholder="Nome" required>
          </div>
          <div class="form-group">
            <select name="category">
              <option value="frontend">Frontend</option>
              <option value="backend">Backend</option>
              <option value="devops">DevOps</option>
              <option value="other">Outro</option>
            </select>
          </div>
          <div class="form-group">
            <input type="text" name="icon_class" placeholder="Icon class (ex: fab fa-react)">
          </div>
          <button type="submit" class="btn btn-primary">Adicionar</button>
        </div>
      </form>
    </div>
  </div>
  <div class="card">
    <div class="card-body">
      <% if (skills && skills.length > 0) { %>
        <table class="table">
          <thead>
            <tr>
              <th>Nome</th>
              <th>Categoria</th>
              <th>Ícone</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% skills.forEach(function(s) { %>
              <tr>
                <td><%= s.name %></td>
                <td><span class="badge badge-category"><%= s.category %></span></td>
                <td><i class="<%= s.icon_class || 'fas fa-code' %>"></i></td>
                <td class="actions">
                  <form action="/admin/skills/edit/<%= s.id %>" method="POST" class="inline-form" style="display:inline-flex;gap:8px;flex-wrap:wrap">
                    <input type="text" name="name" value="<%= s.name %>" style="width:100px" required>
                    <select name="category" style="width:100px">
                      <option value="frontend" <%= s.category === 'frontend' ? 'selected' : '' %>>Frontend</option>
                      <option value="backend" <%= s.category === 'backend' ? 'selected' : '' %>>Backend</option>
                      <option value="devops" <%= s.category === 'devops' ? 'selected' : '' %>>DevOps</option>
                      <option value="other" <%= s.category === 'other' ? 'selected' : '' %>>Outro</option>
                    </select>
                    <input type="text" name="icon_class" value="<%= s.icon_class || '' %>" style="width:100px">
                    <button type="submit" class="btn btn-sm btn-edit"><i class="fas fa-check"></i></button>
                  </form>
                  <form action="/admin/skills/delete/<%= s.id %>" method="POST" class="inline-form" onsubmit="return confirm('Tem certeza?')">
                    <button type="submit" class="btn btn-sm btn-delete"><i class="fas fa-trash"></i></button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <p class="empty-state">Nenhuma habilidade cadastrada.</p>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/admin-footer') %>
